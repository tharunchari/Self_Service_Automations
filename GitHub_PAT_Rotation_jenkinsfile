pipeline {
    agent {
        label 'V3LOCITY-SLAVE-OEL9-01'
    }

    environment {
        NEW_PROD_PAT = credentials('github_prod_pat')
        NEW_INFRA_PAT = credentials('github_infra_pat')
        NEW_QA_PAT   = credentials('github_qa_pat')
        svn          = credentials('svn_service_account')
    }

    stages {

        stage('Starting Pipeline Email Notify') {
            steps {
                script {
                    sh '''
                    #echo "GIT-HUB PAT plan has been initiated, monitor here ${BUILD_URL}" | \
                    #mailx -r "v3atlassianops@vitechinc.com" -s "GitHub PAT Rotation for Service Account" \
                    #v3ops@vitechinc.com,SRE-Team@Vitechsg.onmicrosoft.com
                    '''
                }
            }
        }

        stage('Retrieve Credential') {
            steps {
                script {
                    echo "Credentials retrieved successfully and stored in environment variables."
                }
            }
        }

        stage('Update Bamboo GlobalVariable-Value PAT') {
			steps {
				script {
					withCredentials([string(credentialsId: 'BAMBOO_PAT', variable: 'BAMBOO_PAT')]) {
						withCredentials([usernamePassword(credentialsId: 'VITECH-APP-FISHCRU', usernameVariable: 'username', passwordVariable: 'password')]) {
							sh '''
							#!/bin/bash

							update_bamboo_pat() {
							  URL="$1"
							  NEW_PAT="$2"
							  VARIABLE_NAME="$3"

							  echo "Updating Bamboo $VARIABLE_NAME PAT"

							  raw_response=$(curl -s -w "\nHTTP_STATUS:%{http_code}" \
								-H "Authorization: Bearer $BAMBOO_PAT" \
								-H "Accept: application/json" \
								"$URL")

							  http_status=$(echo "$raw_response" | grep "HTTP_STATUS:" | cut -d: -f2)
							  body=$(echo "$raw_response" | sed '/HTTP_STATUS:/d')

							  echo "HTTP Status: $http_status"

							  if echo "$body" | jq -e . > /dev/null 2>&1; then
								old_value=$(echo "$body" | jq -r '.value')
								echo "Old value: $old_value"
							  else
								echo "WARNING: Response is not valid JSON. Skipping old value retrieval."
							  fi

							  # ✅ Fix: Build JSON payload using jq to avoid malformed JSON
							  JSON_PAYLOAD=$(jq -n --arg val "$NEW_PAT" '{"value": $val}')

							  response=$(curl -s -o /dev/null -w "%{http_code}" \
								-X PUT \
								-H "Authorization: Bearer $BAMBOO_PAT" \
								-H "Content-Type: application/json" \
								-H "Accept: application/json" \
								-d "$JSON_PAYLOAD" \
								"$URL")

							  echo "Update response code: $response"

							  if [ "$response" -eq 200 ]; then
								echo "Update successful."
							  else
								echo "Update failed with status code: $response"
								exit 1
							  fi
							}

							update_bamboo_pat "https://bamboo.vitechinc.com/bamboo/rest/admin/latest/globalVariables/153668343" "$NEW_PROD_PAT" "Git Prod"
							update_bamboo_pat "https://bamboo.vitechinc.com/bamboo/rest/admin/latest/globalVariables/149001826" "$NEW_QA_PAT" "Git QA"
							update_bamboo_pat "https://bamboo.vitechinc.com/bamboo/rest/admin/latest/globalVariables/161908561" "$NEW_INFRA_PAT" "Git Infra"
							'''
						}
					}
				}
			}
		}
		
        stage('Update EBR-Secret PAT') {
            steps {
                script {
                    sh '''
                    set -e
                    export AWS_PROFILE="v3locitydev"

                    SECRET_ARN="arn:aws:secretsmanager:us-east-1:866159464259:secret:EBR_SECRETS-IVnHZq"

                    if aws secretsmanager describe-secret --secret-id "$SECRET_ARN" --region us-east-1 > /dev/null 2>&1; then
                        echo "Updating EBR secret: $SECRET_ARN"

                        secret_value=$(aws secretsmanager get-secret-value \
                            --region us-east-1 \
                            --secret-id "$SECRET_ARN" \
                            --query 'SecretString' --output text)

                        echo "Current Secret: **** (hidden for security)"

                        updated_secret_value=$(echo "$secret_value" | jq --arg NEW_PROD_PAT "$NEW_PROD_PAT" --arg NEW_INFRA_PAT "$NEW_INFRA_PAT" \
                            '.github_vitechpat = $NEW_PROD_PAT | .github_pat = $NEW_INFRA_PAT')

                        aws secretsmanager update-secret \
                            --region us-east-1 \
                            --secret-id "$SECRET_ARN" \
                            --secret-string "$updated_secret_value"

                        echo "EBR secret updated successfully."
                    else
                        echo "Secret $SECRET_ARN not found. Skipping..."
                    fi
                    '''
                }
            }
        }

        stage('Update V3locitydev-Secret PAT') {
            steps {
                script {
                    sh '''
                    set -e
                    export AWS_PROFILE="v3locitydev"

                    secret_arns=(
                        "arn:aws:secretsmanager:us-east-1:866159464259:secret:v3ops_github_service_pat-9lQZIk"
                        "arn:aws:secretsmanager:ca-central-1:866159464259:secret:v3ops_github_service_pat-XcsUxb"
                    )

                    for secret_arn in "${secret_arns[@]}"; do
                        region=$(echo "$secret_arn" | cut -d: -f4)

                        if aws secretsmanager describe-secret --secret-id "$secret_arn" --region "$region" > /dev/null 2>&1; then
                            echo "Updating secret $secret_arn in region $region"
                            aws secretsmanager update-secret --region "$region" --secret-id "$secret_arn" --secret-string "$NEW_INFRA_PAT"
                            echo "Updated successfully."
                        else
                            echo "Secret $secret_arn not found in $region. Skipping..."
                        fi
                    done
                    '''
                }
            }
        }

        stage('Update V3locity-Secret PAT') {
            steps {
                script {
                    sh '''
                    set -e
                    export AWS_PROFILE="v3locity"

                    secret_arns=(
                        "arn:aws:secretsmanager:us-east-1:734006704080:secret:v3ops_github_service_pat-wnqizU"
                        "arn:aws:secretsmanager:ca-central-1:734006704080:secret:v3ops_github_service_pat-HEUaq3"
                        "arn:aws:secretsmanager:eu-west-1:734006704080:secret:v3ops_github_service_pat-3PMpwP"
						"arn:aws:secretsmanager:us-west-2:734006704080:secret:v3ops_github_service_pat-IrqGav"
						"arn:aws:secretsmanager:ca-west-1:734006704080:secret:v3ops_github_service_pat-vePxtZ"
                    )

                    for secret_arn in "${secret_arns[@]}"; do
                        region=$(echo "$secret_arn" | cut -d: -f4)

                        if aws secretsmanager describe-secret --secret-id "$secret_arn" --region "$region" > /dev/null 2>&1; then
                            echo "Updating secret $secret_arn in region $region"
                            aws secretsmanager update-secret --region "$region" --secret-id "$secret_arn" --secret-string "$NEW_INFRA_PAT"
                            echo "Updated successfully."
                        else
                            echo "Secret $secret_arn not found in $region. Skipping..."
                        fi
                    done
                    '''
                }
            }
        }

        stage('Update V3locitydev Vitechsystems Git PATs') {
            steps {
                script {
                    sh '''
                    set -e
                    export AWS_PROFILE="v3locitydev"

                    secret_arns=(
                        "arn:aws:secretsmanager:ca-central-1:866159464259:secret:v3ops_vitechsystems_git_pat-W03hJX"
                        "arn:aws:secretsmanager:us-east-1:866159464259:secret:v3ops_vitechsystems_git_pat-QNbaIh"
                    )

                    for secret_arn in "${secret_arns[@]}"; do
                        region=$(echo "$secret_arn" | cut -d: -f4)
                        if aws secretsmanager describe-secret --secret-id "$secret_arn" --region "$region" > /dev/null 2>&1; then
                            echo "Updating secret $secret_arn in region $region"
                            aws secretsmanager update-secret --region "$region" --secret-id "$secret_arn" --secret-string "$NEW_PROD_PAT"
                            echo "Updated successfully."
                        else
                            echo "Secret $secret_arn not found in $region. Skipping..."
                        fi
                    done
                    '''
                }
            }
        }

        stage('Update V3locity Vitechsystems Git PATs - v3locity') {
            steps {
                script {
                    sh '''
                    set -e
                    export AWS_PROFILE="v3locity"

                    secret_arns=(
                        "arn:aws:secretsmanager:ca-central-1:734006704080:secret:v3ops_vitechsystems_git_pat-xoFptg"
                        "arn:aws:secretsmanager:eu-west-1:734006704080:secret:v3ops_vitechsystems_git_pat-KaoGvV"
                        "arn:aws:secretsmanager:us-east-1:734006704080:secret:v3ops_vitechsystems_git_pat-eZ2T4O"
						"arn:aws:secretsmanager:us-west-2:734006704080:secret:v3ops_vitechsystems_git_pat-POLl8R"
						"arn:aws:secretsmanager:ca-west-1:734006704080:secret:v3ops_vitechsystems_git_pat-NsvZJk"
                    )

                    for secret_arn in "${secret_arns[@]}"; do
                        region=$(echo "$secret_arn" | cut -d: -f4)
                        if aws secretsmanager describe-secret --secret-id "$secret_arn" --region "$region" > /dev/null 2>&1; then
                            echo "Updating secret $secret_arn in region $region"
                            aws secretsmanager update-secret --region "$region" --secret-id "$secret_arn" --secret-string "$NEW_PROD_PAT"
                            echo "Updated successfully."
                        else
                            echo "Secret $secret_arn not found in $region. Skipping..."
                        fi
                    done
                    '''
                }
            }
        }

        stage('Update GitHub Secrets') {
			steps {
				script {
					def orgs = ['vitechsystems', 'VitechInfra', 'VitechQA']
					def secrets = [
						[name: 'INFRA_FINE_GRAINED_PAT', value: env.NEW_INFRA_PAT],
						[name: 'PROD_FINE_GRAINED_PAT',  value: env.NEW_PROD_PAT],
						[name: 'QA_FINE_GRAINED_PAT',    value: env.NEW_QA_PAT]
					]
					def adminTokens = [
						'vitechsystems': env.NEW_PROD_PAT,
						'VitechInfra'  : env.NEW_INFRA_PAT,
						'VitechQA'     : env.NEW_QA_PAT
					]

					// Write Python encryption script using printf in a single-quoted shell block
					// Single quotes ensure Groovy does NOT interpolate anything
					sh '''
		printf '%s\n' \
		'import base64' \
		'import os' \
		'import sys' \
		'from nacl import encoding, public' \
		'' \
		'token  = os.environ["SECRET_TOKEN"]' \
		'pubkey = sys.argv[1]' \
		'' \
		'key    = public.PublicKey(base64.b64decode(pubkey), encoding.RawEncoder())' \
		'sealed = public.SealedBox(key)' \
		'print(base64.b64encode(sealed.encrypt(token.encode())).decode())' \
		> "$WORKSPACE/encrypt.py"
		echo "=== encrypt.py contents ==="
		cat "$WORKSPACE/encrypt.py"
		'''

					orgs.each { org ->
						secrets.each { s ->
							def adminPat   = adminTokens[org]
							def secretName = s.name

							// Write secret values to temp files via Groovy writeFile
							// This avoids passing secrets through shell string interpolation entirely
							def tokenFile = "${env.WORKSPACE}/secret_token_${secretName}_${org}.tmp"
							def patFile   = "${env.WORKSPACE}/admin_pat_${org}.tmp"

							writeFile file: tokenFile, text: s.value
							writeFile file: patFile,   text: adminPat

							sh """
							set -e

							# Read secrets from temp files - never exposed via shell interpolation
							SECRET_TOKEN=\$(cat "${tokenFile}")
							ADMIN_PAT_TOKEN=\$(cat "${patFile}")

							# Always clean up secret temp files on exit (success or failure)
							trap 'rm -f "${tokenFile}" "${patFile}"' EXIT

							echo "Updating GitHub secret '${secretName}' for org '${org}'"

							TMP_DIR=\$(mktemp -d)
							trap 'rm -rf "\$TMP_DIR"; rm -f "${tokenFile}" "${patFile}"' EXIT

							# Fetch the org's public key for secret encryption
							curl -s \\
								-H "Authorization: token \$ADMIN_PAT_TOKEN" \\
								-H "Accept: application/vnd.github.v3+json" \\
								"https://api.github.com/orgs/${org}/actions/secrets/public-key" > "\$TMP_DIR/pubkey.json"

							KEY_ID=\$(jq -r '.key_id' "\$TMP_DIR/pubkey.json")
							PUBKEY=\$(jq -r '.key' "\$TMP_DIR/pubkey.json")

							if [ -z "\$KEY_ID" ] || [ -z "\$PUBKEY" ]; then
								echo "ERROR: Failed to retrieve public key for org '${org}'"
								exit 1
							fi

							echo "Retrieved public key for org '${org}' (KEY_ID: \$KEY_ID)"

							# Encrypt the secret value using the org's public key
							export SECRET_TOKEN
							ENCRYPTED_VALUE=\$(python3 "\$WORKSPACE/encrypt.py" "\$PUBKEY")

							if [ -z "\$ENCRYPTED_VALUE" ]; then
								echo "ERROR: Encrypted value is empty for secret '${secretName}' in org '${org}'"
								exit 1
							fi

							echo "Encryption successful for secret '${secretName}'"

							# Push the encrypted secret to GitHub
							RESPONSE=\$(curl -s -w "\\nHTTP_STATUS:%{http_code}\\n" -X PUT \\
								-H "Authorization: token \$ADMIN_PAT_TOKEN" \\
								-H "Accept: application/vnd.github.v3+json" \\
								-d "{\\"encrypted_value\\": \\"\$ENCRYPTED_VALUE\\", \\"key_id\\": \\"\$KEY_ID\\", \\"visibility\\": \\"all\\"}" \\
								"https://api.github.com/orgs/${org}/actions/secrets/${secretName}")

							HTTP_STATUS=\$(echo "\$RESPONSE" | grep "HTTP_STATUS:" | cut -d: -f2)
							BODY=\$(echo "\$RESPONSE" | grep -v "HTTP_STATUS:")

							echo "GitHub API response body: \$BODY"
							echo "GitHub API HTTP status:   \$HTTP_STATUS"

							# 201 = secret created (new), 204 = secret updated (existing)
							if [ "\$HTTP_STATUS" = "201" ] || [ "\$HTTP_STATUS" = "204" ]; then
								echo "SUCCESS: Secret '${secretName}' updated for org '${org}' (HTTP \$HTTP_STATUS)"
							else
								echo "ERROR: Failed to update secret '${secretName}' for org '${org}' (HTTP \$HTTP_STATUS)"
								echo "Response body: \$BODY"
								exit 1
							fi
							"""
						}
					}
				}
			}
		}	
		stage('Update PrecommitLambda PAT') {
			steps {
				script {
					sh '''
						set -e
						export AWS_PROFILE="JIRA-Account"

						# Generate timestamp prefix for backup
						TIMESTAMP=$(date +"%Y-%m-%d_%H-%M-%S")
						BACKUP_PREFIX="s3://vitechtoolsnv/PrecommitLambda/backup_${TIMESTAMP}"

						echo "=== Starting backup with prefix: ${BACKUP_PREFIX} ==="

						# -------------------------------------------------------
						# BACKUP 1: Save full Lambda configuration (env vars etc.) to S3
						# -------------------------------------------------------
						echo "Backing up Lambda configuration (env vars)..."
						aws lambda get-function-configuration \
						  --function-name PrecommitLambda \
						  --region us-east-1 \
						  > /tmp/lambda_config_${TIMESTAMP}.json

						aws s3 cp /tmp/lambda_config_${TIMESTAMP}.json \
						  "${BACKUP_PREFIX}/lambda_config.json"
						echo "Lambda config backed up successfully."

						# -------------------------------------------------------
						# BACKUP 2: Download function code .zip and upload to S3
						# -------------------------------------------------------
						echo "Backing up Lambda function code (.zip)..."
						CODE_URL=$(aws lambda get-function \
						  --function-name PrecommitLambda \
						  --region us-east-1 \
						  | jq -r '.Code.Location')

						curl -s -o /tmp/PrecommitLambda_code_${TIMESTAMP}.zip "$CODE_URL"

						aws s3 cp /tmp/PrecommitLambda_code_${TIMESTAMP}.zip \
						  "${BACKUP_PREFIX}/PrecommitLambda_code.zip"
						echo "Function code (.zip) backed up successfully."

						echo "=== All backups completed at: ${BACKUP_PREFIX} ==="
						echo "-------------------------------------------------------"

						# -------------------------------------------------------
						# UPDATE: Merge new PATs into existing env vars
						# -------------------------------------------------------
						echo "Fetching existing Lambda environment variables..."
						existing_vars=$(aws lambda get-function-configuration \
						  --function-name PrecommitLambda \
						  --region us-east-1 | jq -r '.Environment.Variables')

						echo "Merging new PATs into existing environment variables..."
						updated_vars=$(echo "$existing_vars" | jq -c \
						  --arg GITHUB_KEY "${NEW_PROD_PAT}" \
						  --arg GITHUB_KEY_VITECHINFRA "${NEW_INFRA_PAT}" \
						  --arg GITHUB_KEY_VITECHQA "${NEW_QA_PAT}" \
						  --arg GITHUB_KEY_VITECHSYSTEMS "${NEW_PROD_PAT}" \
						  '. + {
							GITHUB_KEY: $GITHUB_KEY,
							GITHUB_KEY_VITECHINFRA: $GITHUB_KEY_VITECHINFRA,
							GITHUB_KEY_VITECHQA: $GITHUB_KEY_VITECHQA,
							GITHUB_KEY_VITECHSYSTEMS: $GITHUB_KEY_VITECHSYSTEMS
						  }')

						env_args="Variables=$(echo $updated_vars | jq -r 'to_entries | map(.key + "=" + (.value|tostring)) | join(",")')"

						echo "Updating Lambda environment variables..."
						aws lambda update-function-configuration \
						  --function-name PrecommitLambda \
						  --region us-east-1 \
						  --environment "$env_args"

						echo "Lambda environment variables updated successfully."

						# -------------------------------------------------------
						# Cleanup temp files
						# -------------------------------------------------------
						rm -f /tmp/lambda_config_${TIMESTAMP}.json \
							  /tmp/PrecommitLambda_code_${TIMESTAMP}.zip

						echo "=== Stage completed successfully ==="
					'''
				}
			}
		}
        stage('Ending Pipeline Email Notify') {
            steps {
                script {
                    sh '''
                    #echo "GIT-HUB PAT Update completed" | \
                    #mailx -r "v3atlassianops@vitechinc.com" -s "GitHub PAT Rotation Completed" \
                    #v3ops@vitechinc.com,SRE-Team@Vitechsg.onmicrosoft.com
                    '''
                }
            }
        }

    }
}
