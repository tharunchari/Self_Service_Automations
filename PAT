pipeline {
    agent {
        label 'Ansible-VM'
    }

    environment {
        SECRET = credentials('manitesting')  // Retrieving a secret
    }

    stages {
        stage('Retrieve Credential') {
            steps {
                script {
                    echo "Credential retrieved successfully and stored in NEW_VALUE."
                    env.NEW_VALUE = SECRET  // Store the retrieved secret in NEW_VALUE
                }
            }
        }

        stage('Update Bamboo GlobalVariable Value') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'bamboorestuser', usernameVariable: 'BAMBOO_USER', passwordVariable: 'BAMBOO_PASSWORD')]) {
                        withCredentials([usernamePassword(credentialsId: 'VITECH-APP-FISHCRU', usernameVariable: 'username', passwordVariable: 'password')]) {
                            sh '''
                            # Define URL and NEW_VALUE
                            URL="https://bamboo.vitechinc.com/bamboo/rest/admin/latest/globalVariables/175127920"
                            NEW_VALUE="${NEW_VALUE}"

                            # Get the old value of the variable
                            old_value=$(curl -s -u $BAMBOO_USER:$BAMBOO_PASSWORD "$URL" | jq -r '.value')                    
                            echo "Old value: $old_value"  

                            # Test connection with sshpass and SSH command
                            sshpass -p "$password" ssh -o StrictHostKeyChecking=no "$username"@172.26.44.151 "echo 'This is a test file' > /tmp/testfile.txt"
							sshpass -p "$password" ssh -o StrictHostKeyChecking=no "$username"@172.26.44.151 "echo "curl -s -o /dev/null -w \"%{http_code}\" -X PUT -u \$USERNAME:\$PASSWORD \"\$URL\" -H \"Content-Type: application/json\" -d \"{\\\"value\\\":\\\"\$NEW_VALUE\\\"}\"" > /tmp/curl.txt"

                            # Update the value in Bamboo
                            set -x
							curl -s -o /dev/null -w "%{http_code}" -X PUT -u $USERNAME:$PASSWORD "$URL" -H "Content-Type: application/json" -d "{\"value\":\"$NEW_VALUE\"}"

							# Check if the update was successful
							if [ "$response" -eq 200 ]; then
								echo "Update successful. New value set to: $NEW_VALUE"
							else
								echo "Update failed with status code: $response"
								exit 1
							fi
                            '''
                        }
                    }
                }
            }
        }

        stage('Update AWS Secret') {
            steps {
                script {
                    sh """
                        export AWS_PROFILE="v3locitydev"
                        NEW_VALUE="${NEW_VALUE}"  
                        secret_arn="arn:aws:secretsmanager:us-east-1:866159464259:secret:EBR_SECRETS-IVnHZq"
                        secret_value=\$(aws secretsmanager get-secret-value --secret-id \$secret_arn --query 'SecretString' --output text)
                        github_pat_value=\$(echo \$secret_value | jq -r '.Testing')
                        echo "Current github_pat value: \$github_pat_value" 
                        updated_secret_value=\$(echo \$secret_value | jq --arg new_value "\$NEW_VALUE" '.Testing = \$new_value')
                        aws secretsmanager update-secret --secret-id \$secret_arn --secret-string "\$updated_secret_value"                       
                        echo "AWS secret 'EBR_SECRETS' updated with new github_pat value."
                    """
                }
            }
        }

        stage('Update Crowd pat') {
            steps {
                script {                   
                    withCredentials([usernamePassword(credentialsId: 'VITECH-APP-FISHCRU', usernameVariable: 'username', passwordVariable: 'password')]) {
                        sh '''
                        NEW_VALUE="${NEW_VALUE}"  
                        sshpass -p "$password" ssh -o StrictHostKeyChecking=no "$username"@172.26.44.151 "first_github_pat=\$(grep -o 'github_pat\\w*' /tmp/config.xml | head -n 1) && sed -i 's/\$first_github_pat/\$NEW_VALUE/' /tmp/config.xml && echo 'Crowd pat updated successfully.'"
                        '''
                    }
                }
            }
        }

        stage('update_pat_svn') {
            steps {
                script {
                    sh '''
                    NEW_VALUE="${NEW_VALUE}"
                    rm -rf /tmp/Internal_tools
                    svn --non-interactive --no-auth-cache --username ${svn_USR} --password ${svn_PSW} --force checkout https://repo.vitechinc.com/repos/deployment/trunk/InternalTools/automation/ /tmp/Internal_tools    
                    cd /tmp/Internal_tools
                    first_github_pat=\$(grep -o 'github_pat\\w*' /tmp/InternalTools/* | head -n 1)
                    sed -i 's/$first_github_pat/$NEW_VALUE/g' .
                    echo "DEPLOYMENT: Updated PAT with new value " >> svn.txt
                    #svn commit -F svn.txt
                    rm -rf /tmp/Internal_tools
                    '''
                }
            }
        }
    }
}
