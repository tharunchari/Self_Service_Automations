sonarQube:
    name: SonarQube Analysis
    runs-on: ubuntu-latest
    needs: codeql 

    steps:
      - name: Checkout repository
        uses: actions/checkout@v2

      - name: Set up JDK 11
        uses: actions/setup-java@v2
        with:
          java-version: '11'

      - name: Cache SonarQube packages
        uses: actions/cache@v2
        with:
          path: ~/.sonar/cache
          key: ${{ runner.os }}-sonar

      - name: SonarQube Scan
        env:
          SONAR_TOKEN: ${{ eca76b827c161d40deeb162b5ec333b7f7946f27 }}
        run: |
          ./gradlew sonarqube -Dsonar.projectKey=your_project_key -Dsonar.organization=your_organization_key -Dsonar.host.url=https://v3qa.vitechinc.com/sonarv310ucqa -Dsonar.login=${{ eca76b827c161d40deeb162b5ec333b7f7946f27 }}
